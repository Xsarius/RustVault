# Authentication messages
# Project Fluent format — https://projectfluent.org/

login-success = Successfully logged in.
login-failed = Invalid email or password.
login-locked = Account locked. Try again in { $minutes } minutes.
register-success = Account created successfully.
register-email-taken = An account with this email already exists.
logout-success = Successfully logged out.
token-expired = Session expired. Please log in again.
token-invalid = Invalid authentication token.
password-too-short = Password must be at least { $min } characters.
password-too-long = Password must be at most { $max } characters.
oidc-not-configured = Single sign-on is not configured.
oidc-use-sso = Please use SSO to sign in.
